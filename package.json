{
  "name": "piu",
  "version": "1.1.1",
  "description": "Piu - Gestión de producción de cocina comercial",
  "author": "Piu Team",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox --dev\"",
    "build:vite": "vite build",
    "start": "electron . --no-sandbox",
    "preview": "vite build && electron . --no-sandbox",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:linux": "vite build && electron-builder --linux",
    "pack": "vite build && electron-builder --dir"
  },
  "build": {
    "appId": "com.piu.app",
    "productName": "Piu",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Piu"
    },
    "extraResources": [
      {
        "from": "seed.js",
        "to": "seed.js"
      },
      {
        "from": "test.js",
        "to": "test.js"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ]
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "jimp": "^1.6.1",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
